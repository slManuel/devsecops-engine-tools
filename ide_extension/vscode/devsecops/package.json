{
  "name": "devsecops",
  "icon": "resources/icon.png",
  "displayName": "DevSecOps Engine Tools",
  "publisher": "GrupoBancolombiaOSPO",
  "description": "",
  "version": "1.25.0",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devsecops",
          "title": "DevSecOps IDE Extension",
          "icon": "resources/logo.svg"
        }
      ]
    },
    "views": {
      "devsecops": [
        {
          "id": "devsecops-practices",
          "name": "Practices",
          "icon": "resources/logo.svg"
        },
        {
          "id": "devsecops-results",
          "name": "Results",
          "icon": "resources/logo.svg"
        }
      ]
    },
    "configuration": [
      {
        "title": "General",
        "properties": {
          "devsecops.general.enabled": {
            "type": "boolean",
            "default": true,
            "description": "Enable/Disable DevSecOps IDE Extension"
          },
          "devsecops.general.classificationModel": {
            "type": "string",
            "default": "severity",
            "enum": [
              "severity",
              "priority"
            ],
            "enumDescriptions": [
              "Use the severity model for classification (critical, high, medium, low)",
              "Use the priority model for classification (very critical, critical, high, medium low)"
            ],
            "description": "Choose which model to use for vulnerability classification"
          },
          "devsecops.general.timeout": {
            "type": "number",
            "default": 600,
            "minimum": 60,
            "description": "Maximum time (in seconds) to wait for scan completion. Default: 600 seconds (10 minutes)"
          },
          "devsecops.general.debugMode": {
            "type": "boolean",
            "default": false,
            "description": "Enable debug mode to show detailed scan logs"
          }
        }
      },
      {
        "title": "Execution",
        "properties": {
          "devsecops.scanExecutionMode": {
            "type": "string",
            "default": "local-docker",
            "enum": [
              "local-docker",
              "remote-microservice"
            ],
            "enumDescriptions": [
              "Execute scans locally using Docker containers",
              "Execute scans remotely using the DevSecOps microservice"
            ],
            "description": "Scan execution mode: local Docker containers or remote microservice"
          },
          "devsecops.general.imageToUse": {
            "type": "string",
            "default": "bancolombia/devsecops-engine-tools:ide-v1",
            "description": "Base container image used for local Docker scanning. Should include a tag."
          },
          "devsecops.general.engineToolsVersion": {
            "type": "string",
            "description": "DevSecOps Engine Tools version to install inside the container. Leave empty to use the latest available version."
          },
          "devsecops.general.customRemoteConfigPath": {
            "type": "string",
            "description": "Optional path to a local directory containing a custom remote config for the scanner image. When set, this directory is mounted into the container at runtime and used instead of the default config baked into the image. Leave empty to use the image's default config (ide_extension/remote_config)."
          },
          "devsecops.microserviceUrl": {
            "type": "string",
            "description": "URL of the DevSecOps scanning microservice (required for remote-microservice mode)",
            "pattern": "^https?://.*",
            "patternErrorMessage": "Must be a valid HTTP or HTTPS URL"
          }
        }
      },
      {
        "title": "IaC Scan",
        "properties": {
          "devsecops.iac.iacTool": {
            "type": "string",
            "default": "checkov",
            "enum": [
              "checkov",
              "kics"
            ],
            "description": "IaC Scan Tool to use (Checkov to scan Terraform, CloudFormation, Kubernetes, Dockerfile and OpenAPI; KICS to scan OpenAPI)"
          },
          "devsecops.iac.customRulesUrl": {
            "type": "string",
            "description": "URL of the custom rules service used to fetch custom IaC validation rules",
            "pattern": "^https?://.*",
            "patternErrorMessage": "Must be a valid HTTP or HTTPS URL"
          }
        }
      },
      {
        "title": "Dependencies Scan",
        "properties": {
          "devsecops.dependencies.dependenciesToken": {
            "type": "string",
            "description": "Token for dependencies scan (Jfrog Token for Xray or NVD Api Key for Dependency Check)",
            "format": "password"
          },
          "devsecops.dependencies.dependenciesTool": {
            "type": "string",
            "default": "trivy",
            "enum": [
              "xray",
              "dependency_check",
              "trivy"
            ],
            "description": "Dependency Scan Tool to use"
          },
          "devsecops.dependencies.xrayMode": {
            "type": "string",
            "default": "audit",
            "enum": [
              "audit",
              "scan"
            ],
            "description": "Dependency scan mode with JFrog Xray (audit = dependency tree scanning, scan = compiled file scan)"
          },
          "devsecops.dependencies.dependencyCheckDatabase": {
            "type": "string",
            "description": "Dependency Check Database path (if using dependency_check tool, will increase performance)"
          }
        }
      },
      {
        "title": "Azure DevOps",
        "properties": {
          "devsecops.azuredevops.organizationName": {
            "type": "string",
            "description": "Organization Name"
          },
          "devsecops.azuredevops.projectName": {
            "type": "string",
            "description": "Project Name"
          },
          "devsecops.azuredevops.variablePlaceholder": {
            "type": "string",
            "default": "#{ ... }#",
            "description": "Characters to identify variables"
          },
          "devsecops.azuredevops.groupName": {
            "type": "string",
            "description": "Variables group name"
          },
          "devsecops.azuredevops.releaseId": {
            "type": "string",
            "description": "Azure Release Definition ID",
            "title": "Definition ID"
          },
          "devsecops.azuredevops.environment": {
            "type": "string",
            "default": "dev",
            "enum": [
              "pdn",
              "cer",
              "qa",
              "dev"
            ],
            "description": "Environment to evaluate"
          },
          "devsecops.azuredevops.username": {
            "type": "string",
            "default": "",
            "description": "Set your Azure DevOps username"
          },
          "devsecops.azuredevops.personalAccessToken": {
            "type": "string",
            "default": "",
            "description": "Set your user personal access token generated at Azure DevOps",
            "format": "password"
          }
        }
      }
    ],
    "commands": [
      {
        "command": "devsecops.iacScan",
        "title": "DevSecOps Iac Scan"
      },
      {
        "command": "devsecops.imageScan",
        "title": "DevSecOps Image Scan"
      },
      {
        "command": "devsecops.dependenciesScan",
        "title": "DevSecOps Dependencies Scan"
      },
      {
        "command": "devsecops.openWithDiagnostic",
        "title": "Open File with Security Diagnostic Highlighting"
      },
      {
        "command": "devsecops.fixWithCopilot",
        "title": "Fix Security Issue with GitHub Copilot"
      },
      {
        "command": "devsecops.explainWithCopilot",
        "title": "Explain Security Issue with GitHub Copilot"
      },
      {
        "command": "devsecops.fixVulnerabilityWithCopilot",
        "title": "Fix Vulnerability with GitHub Copilot"
      },
      {
        "command": "devsecops.explainVulnerabilityWithCopilot",
        "title": "Explain Vulnerability with GitHub Copilot"
      },
      {
        "command": "devsecops.showGeneralFindingWebview",
        "title": "Show Finding Details"
      },
      {
        "command": "devsecops.generateDependencyUpdate",
        "title": "Generate Dependency Update Solution"
      },
      {
        "command": "devsecops.autoFixDependenciesWithAgent",
        "title": "Auto-Fix Dependencies with Copilot Agent"
      },
      {
        "command": "devsecops.deleteScanResult",
        "title": "Delete Scan Result"
      },
      {
        "command": "devsecops.filterBySeverity",
        "title": "Filter by Severity/Priority",
        "icon": "$(filter)"
      },
      {
        "command": "devsecops.toggleSort",
        "title": "Toggle Sort by Severity/Priority",
        "icon": "$(sort-precedence)"
      },
      {
        "command": "devsecops.clearFilters",
        "title": "Clear Filters",
        "icon": "$(clear-all)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "devsecops.filterBySeverity",
          "when": "view == devsecops-results",
          "group": "navigation@1"
        },
        {
          "command": "devsecops.toggleSort",
          "when": "view == devsecops-results",
          "group": "navigation@2"
        },
        {
          "command": "devsecops.clearFilters",
          "when": "view == devsecops-results",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "devsecops.fixVulnerabilityWithCopilot",
          "when": "view == devsecops-results && viewItem == findingItem",
          "group": "copilot@1"
        },
        {
          "command": "devsecops.explainVulnerabilityWithCopilot",
          "when": "view == devsecops-results && viewItem == findingItem",
          "group": "copilot@2"
        },
        {
          "command": "devsecops.fixVulnerabilityWithCopilot",
          "when": "view == devsecops-results && viewItem == engine_iac",
          "group": "copilot@1"
        },
        {
          "command": "devsecops.explainVulnerabilityWithCopilot",
          "when": "view == devsecops-results && viewItem == engine_iac",
          "group": "copilot@2"
        },
        {
          "command": "devsecops.showGeneralFindingWebview",
          "when": "view == devsecops-results && viewItem == engine_iac",
          "group": "details@1"
        },
        {
          "command": "devsecops.fixVulnerabilityWithCopilot",
          "when": "view == devsecops-results && viewItem == engine_secrets",
          "group": "copilot@1"
        },
        {
          "command": "devsecops.explainVulnerabilityWithCopilot",
          "when": "view == devsecops-results && viewItem == engine_secrets",
          "group": "copilot@2"
        },
        {
          "command": "devsecops.generateDependencyUpdate",
          "when": "view == devsecops-results && viewItem == findingItem-dependencies",
          "group": "copilot@3"
        },
        {
          "command": "devsecops.autoFixDependenciesWithAgent",
          "when": "view == devsecops-results && viewItem == findingItem-dependencies",
          "group": "copilot@4"
        },
        {
          "command": "devsecops.showGeneralFindingWebview",
          "when": "view == devsecops-results && viewItem == engine_secrets",
          "group": "details@1"
        },
        {
          "command": "devsecops.deleteScanResult",
          "when": "view == devsecops-results && viewItem == scanResult",
          "group": "management@1"
        },
        {
          "command": "devsecops.deleteScanResult",
          "when": "view == devsecops-results && viewItem == scanResult-loading",
          "group": "management@1"
        },
        {
          "command": "devsecops.deleteScanResult",
          "when": "view == devsecops-results && viewItem == scanResult-error",
          "group": "management@1"
        }
      ]
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bancolombia/devsecops-engine-tools"
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "test": "node ./run-tests.js",
    "test:coverage": "nyc npm run test",
    "report:coverage": "nyc report --reporter=lcov --reporter=text",
    "deploy": "vsce publish",
    "lint": "eslint 'src/**/*.{ts,js}'",
    "lint:fix": "eslint 'src/**/*.{ts,js}' --fix",
    "format": "prettier --write 'src/**/*.{ts,js,json,md,html,css,yml,yaml}'",
    "format:check": "prettier --check 'src/**/*.{ts,js,json,md,html,css,yml,yaml}'",
    "prepare": "husky"
  },
  "nyc": {
    "extension": [
      ".ts"
    ],
    "exclude": [
      "**/*.d.ts",
      "**/test/**",
      ".vscode-test/**"
    ],
    "all": true,
    "reporter": [
      "html",
      "text"
    ]
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,html,css,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.2",
    "@semantic-release/release-notes-generator": "^14.0.3",
    "@types/mocha": "^10.0.9",
    "@types/node": "^20.19.35",
    "@types/sinon": "^17.0.4",
    "@types/vscode": "^1.91.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vscode/test-cli": "^0.0.9",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0",
    "mocha": "^11.1.0",
    "mocha-lcov-reporter": "^1.3.0",
    "nyc": "^17.1.0",
    "prettier": "^3.5.3",
    "semantic-release": "^24.2.4",
    "sinon": "^20.0.0",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@types/archiver": "^7.0.0",
    "@types/form-data": "^2.5.2",
    "archiver": "^7.0.1",
    "form-data": "^4.0.5",
    "generator-code": "^1.11.9"
  }
}
