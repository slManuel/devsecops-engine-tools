{
  "name": "devsecops",
  "icon": "resources/logo.png",
  "displayName": "devsecops",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.91.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsWelcome": [
      {
        "view": "scm",
        "contents": "Test",
        "when": "devsecops.enabled"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devsecops",
          "title": "DevSecOps IDE Extension",
          "icon": "resources/logo.svg"
        }
      ]
    },
    "views": {
      "devsecops": [
        {
          "id": "devsecops",
          "name": "DevSecOps IDE Extension",
          "icon": "resources/logo.svg"
        }
      ]
    },
    "configuration": {
      "title": "DevSecOps",
      "properties": {
        "devsecops.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/Disable DevSecOps IDE Extension"
        },
        "devsecops.imageToUse": {
          "type": "string",
          "default": "bancolombia/devsecops-engine-tools",
          "description": "Docker image to use for scanning"
        },
        "devsecops.organizationName": {
          "type": "string",
          "description": "Organization Name"
        },
        "devsecops.projectName": {
          "type": "string",
          "description": "Project Name"
        },
        "devsecops.variablePlaceholder": {
          "type": "string",
          "default": "#{ ... }#",
          "description": "Characters to identify variables"
        },
        "devsecops.groupName": {
          "type": "string",
          "description": "Variables group name"
        },
        "devsecops.releaseId": {
          "type": "string",
          "description": "Azure Release Definition ID"
        },
        "devsecops.environment": {
          "type": "string",
          "default": "dev",
          "enum": [
            "pdn",
            "cer",
            "qa",
            "dev"
          ],
          "description": "Environment to evaluate"
        },
        "devsecops.username": {
          "type": "string",
          "default": "",
          "description": "Set your azure devops username"
        },
        "devsecops.personalAccessToken": {
          "type": "string",
          "default": "",
          "description": "Set your user personal access token generated at azure devops",
          "format": "password"
        }
      }
    },
    "commands": [
      {
        "command": "devsecops.helloWorld",
        "title": "HELLO WORLD"
      },
      {
        "command": "devsecops.iacScan",
        "title": "DevSecOps Iac Scan"
      },
      {
        "command": "devsecops.imageScan",
        "title": "DevSecOps Image Scan"
      },
      {
        "command": "devsecops.openWithDiagnostic",
        "title": "Open File with Security Diagnostic Highlighting"
      },
      {
        "command": "devsecops.fixWithCopilot",
        "title": "Fix Security Issue with GitHub Copilot"
      },
      {
        "command": "devsecops.explainWithCopilot",
        "title": "Explain Security Issue with GitHub Copilot"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "devsecops.imageScan",
          "when": "view == devsecopsView",
          "group": "navigation"
        },
        {
          "command": "devsecops.iacScan",
          "when": "view == devsecopsView",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "rm -rfv ./out && npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "test": "node ./run-tests.js",
    "deploy": "vsce publish --yarn",
    "lint": "eslint 'src/**/*.{ts,js}'",
    "lint:fix": "eslint 'src/**/*.{ts,js}' --fix",
    "format": "prettier --write 'src/**/*.{ts,js,json,md,html,css,yml,yaml}'",
    "format:check": "prettier --check 'src/**/*.{ts,js,json,md,html,css,yml,yaml}'",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,html,css,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@types/mocha": "^10.0.9",
    "@types/node": "20.x",
    "@types/sinon": "^17.0.4",
    "@types/vscode": "^1.91.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vscode/test-cli": "^0.0.9",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0",
    "mocha": "^11.1.0",
    "prettier": "^3.5.3",
    "sinon": "^20.0.0",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "docker-cli-js": "^2.10.0",
    "keytar": "^7.9.0"
  }
}
