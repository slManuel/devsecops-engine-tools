{
  "name": "devsecops",
  "icon": "resources/logo.png",
  "displayName": "DevSecOps Engine Tools",
  "publisher": "GrupoBancolombiaOSPO",
  "description": "",
  "version": "0.0.7",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:devsecops",
    "onCommand:devsecops.iacScan",
    "onCommand:devsecops.imageScan"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devsecops",
          "title": "DevSecOps IDE Extension",
          "icon": "resources/logo.svg"
        }
      ]
    },
    "views": {
      "devsecops": [
        {
          "id": "devsecops",
          "name": "DevSecOps IDE Extension",
          "icon": "resources/logo.svg"
        }
      ]
    },
    "configuration": {
      "title": "DevSecOps",
      "properties": {
        "devsecops.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/Disable DevSecOps IDE Extension"
        },
        "devsecops.organizationName": {
          "type": "string",
          "default": "GrupoBancolombia",
          "description": "Organization Name"
        },
        "devsecops.projectName": {
          "type": "string",
          "default": "Vicepresidencia Servicios de Tecnología",
          "description": "Project Name"
        },
        "devsecops.variablePlaceholder": {
          "type": "string",
          "default": "#{ ... }#",
          "description": "Characters to identify variables"
        },
        "devsecops.groupName": {
          "type": "string",
          "default": "Empty",
          "description": "Variables group name"
        },
        "devsecops.releaseId": {
          "type": "string",
          "description": "Azure Release Definition ID"
        },
        "devsecops.environment": {
          "type": "string",
          "default": "dev",
          "enum": [
            "pdn",
            "cer",
            "qa",
            "dev"
          ],
          "description": "Environment to evaluate"
        },
        "devsecops.username": {
          "type": "string",
          "default": "",
          "description": "Set your azure devops username"
        },
        "devsecops.personalAccessToken": {
          "type": "string",
          "default": "",
          "description": "Set your user personal access token generated at azure devops",
          "format": "password"
        }
      }
    },
    "commands": [
      {
        "command": "devsecops.iacScan",
        "title": "DevSecOps: Scan IaC"
      },
      {
        "command": "devsecops.imageScan",
        "title": "DevSecOps: Scan Image"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "devsecops.iacScan",
          "when": "view == devsecops",
          "group": "navigation"
        },
        {
          "command": "devsecops.imageScan",
          "when": "view == devsecops",
          "group": "navigation"
        }
      ]
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bancolombia/devsecops-engine-tools"
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test",
    "deploy": "vsce publish"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.2",
    "@semantic-release/release-notes-generator": "^14.0.3",
    "@types/lodash": "^4.17.16",
    "@types/mocha": "^10.0.9",
    "@types/node": "20.x",
    "@types/vscode": "^1.91.0",
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.11.0",
    "@vscode/test-cli": "^0.0.9",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^8.57.0",
    "semantic-release": "^24.2.4",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "docker-cli-js": "^2.10.0",
    "generator-code": "^1.11.9",
    "keytar": "^7.9.0",
    "lodash": "^4.17.21"
  }
}
