{
  "name": "devsecops",
  "icon": "resources/icon.png",
  "displayName": "DevSecOps Engine Tools",
  "publisher": "GrupoBancolombiaOSPO",
  "description": "",
  "version": "1.6.0",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:devsecops",
    "onCommand:devsecops.iacScan",
    "onCommand:devsecops.imageScan",
    "onCommand:devsecops.dependenciesScan"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devsecops",
          "title": "DevSecOps IDE Extension",
          "icon": "resources/logo.svg"
        }
      ]
    },
    "views": {
      "devsecops": [
        {
          "id": "devsecops",
          "name": "DevSecOps IDE Extension",
          "icon": "resources/logo.svg"
        }
      ]
    },
    "configuration": [
      {
        "title": "General Settings",
        "properties": {
          "devsecops.general.enabled": {
            "type": "boolean",
            "default": true,
            "description": "Enable/Disable DevSecOps IDE Extension"
          },
          "devsecops.general.imageToUse": {
            "type": "string",
            "default": "bancolombia/devsecops-engine-tools",
            "description": "Docker image to use for scanning"
          },
          "devsecops.general.imageVersion": {
            "type": "string",
            "default": "1.75.3",
            "description": "Docker image version to use for scanning"
          }
        }
      },
      {
        "title": "Azure DevOps Settings",
        "properties": {
          "devsecops.azuredevops.organizationName": {
            "type": "string",
            "description": "Organization Name"
          },
          "devsecops.azuredevops.projectName": {
            "type": "string",
            "description": "Project Name"
          },
          "devsecops.azuredevops.variablePlaceholder": {
            "type": "string",
            "default": "#{ ... }#",
            "description": "Characters to identify variables"
          },
          "devsecops.azuredevops.groupName": {
            "type": "string",
            "description": "Variables group name"
          },
          "devsecops.azuredevops.releaseId": {
            "type": "string",
            "description": "Azure Release Definition ID"
          },
          "devsecops.azuredevops.environment": {
            "type": "string",
            "default": "dev",
            "enum": [
              "pdn",
              "cer",
              "qa",
              "dev"
            ],
            "description": "Environment to evaluate"
          },
          "devsecops.azuredevops.username": {
            "type": "string",
            "default": "",
            "description": "Set your Azure DevOps username"
          },
          "devsecops.azuredevops.personalAccessToken": {
            "type": "string",
            "default": "",
            "description": "Set your user personal access token generated at Azure DevOps",
            "format": "password"
          }
        }
      },
      {
        "title": "Dependencies Scan Settings",
        "properties": {
          "devsecops.dependencies.dependenciesToken": {
            "type": "string",
            "description": "Token for dependencies scan (Jfrog Token for Xray or NVD Api Key for Dependency Check)",
            "format": "password"
          },
          "devsecops.dependencies.xrayMode": {
            "type": "string",
            "default": "audit",
            "enum": ["audit", "scan"],
            "description": "Dependency scan mode with JFrog Xray (audit = dependency tree scanning, scan = compiled file scan)"
          },
          "devsecops.dependencies.dependenciesTool": {
            "type": "string",
            "default": "xray",
            "enum": ["xray", "dependency_check"],
            "description": "Dependency Scan Tool to use"
          },
          "devsecops.dependencies.dependencyCheckDatabase": {
            "type": "string",
            "description": "Dependency Check Database path (if using dependency_check tool, will increase performance)"
          }
        }
      }
    ],
    "commands": [
      {
        "command": "devsecops.iacScan",
        "title": "DevSecOps Iac Scan"
      },
      {
        "command": "devsecops.imageScan",
        "title": "DevSecOps Image Scan"
      },
      {
        "command": "devsecops.dependenciesScan",
        "title": "DevSecOps Dependencies Scan"
      },
      {
        "command": "devsecops.openWithDiagnostic",
        "title": "Open File with Security Diagnostic Highlighting"
      },
      {
        "command": "devsecops.fixWithCopilot",
        "title": "Fix Security Issue with GitHub Copilot"
      },
      {
        "command": "devsecops.explainWithCopilot",
        "title": "Explain Security Issue with GitHub Copilot"
      },
      {
        "command": "devsecops.fixVulnerabilityWithCopilot",
        "title": "Fix Vulnerability with GitHub Copilot"
      },
      {
        "command": "devsecops.explainVulnerabilityWithCopilot",
        "title": "Explain Vulnerability with GitHub Copilot"
      },
      {
        "command": "devsecops.generateDependencyUpdate",
        "title": "Generate Dependency Update Solution"
      },
      {
        "command": "devsecops.autoFixDependenciesWithAgent",
        "title": "Auto-Fix Dependencies with Copilot Agent"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "devsecops.imageScan",
          "when": "view == devsecopsView",
          "group": "navigation"
        },
        {
          "command": "devsecops.imageScan",
          "when": "view == devsecops",
          "group": "navigation"
        },
        {
          "command": "devsecops.dependenciesScan",
          "when": "view == devsecopsView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "devsecops.fixVulnerabilityWithCopilot",
          "when": "view == devsecops && viewItem == findingItem",
          "group": "copilot@1"
        },
        {
          "command": "devsecops.explainVulnerabilityWithCopilot",
          "when": "view == devsecops && viewItem == findingItem",
          "group": "copilot@2"
        },
        {
          "command": "devsecops.generateDependencyUpdate",
          "when": "view == devsecops && viewItem == findingItem-dependencies",
          "group": "copilot@3"
        },
        {
          "command": "devsecops.autoFixDependenciesWithAgent",
          "when": "view == devsecops && viewItem == findingItem-dependencies",
          "group": "copilot@4"
        }
      ]
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bancolombia/devsecops-engine-tools"
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "test": "node ./run-tests.js",
    "test:coverage": "nyc npm run test",
    "report:coverage": "nyc report --reporter=lcov --reporter=text",
    "deploy": "vsce publish",
    "lint": "eslint 'src/**/*.{ts,js}'",
    "lint:fix": "eslint 'src/**/*.{ts,js}' --fix",
    "format": "prettier --write 'src/**/*.{ts,js,json,md,html,css,yml,yaml}'",
    "format:check": "prettier --check 'src/**/*.{ts,js,json,md,html,css,yml,yaml}'",
    "prepare": "husky"
  },
  "nyc": {
    "extension": [
      ".ts"
    ],
    "exclude": [
      "**/*.d.ts",
      "**/test/**",
      ".vscode-test/**"
    ],
    "all": true,
    "reporter": [
      "html",
      "text"
    ]
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,html,css,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.2",
    "@semantic-release/release-notes-generator": "^14.0.3",
    "@types/lodash": "^4.17.16",
    "@types/mocha": "^10.0.9",
    "@types/node": "20.x",
    "@types/sinon": "^17.0.4",
    "@types/vscode": "^1.91.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vscode/test-cli": "^0.0.9",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0",
    "mocha": "^11.1.0",
    "mocha-lcov-reporter": "^1.3.0",
    "nyc": "^17.1.0",
    "prettier": "^3.5.3",
    "sinon": "^20.0.0",
    "semantic-release": "^24.2.4",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "docker-cli-js": "^2.10.0",
    "generator-code": "^1.11.9",
    "keytar": "^7.9.0",
    "lodash": "^4.17.21"
  }
}
